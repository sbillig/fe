use core::prelude::*
use std::prelude::*

struct Collision {
    log: u256,
    enc: u256,
    data_len: u256,
    data_ptr: u256,
}

impl std::evm::Event for Collision {
    const TOPIC0: u256 = core::keccak(("Collision", "(", u256::SOL_TYPE, ",", u256::SOL_TYPE, ",", u256::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        let mut enc = std::abi::SolEncoder::new()
        let data_len = 0 + u256::ENCODED_SIZE + u256::ENCODED_SIZE
        enc.reserve_head(data_len)
        (self.data_len, self.data_ptr).encode(mut enc)
        let (data_ptr, data_len) = enc.finish()
        log.log3(offset: data_ptr, len: data_len, topic0: Self::TOPIC0, topic1: self.log.as_topic(), topic2: self.enc.as_topic())
    }
}
