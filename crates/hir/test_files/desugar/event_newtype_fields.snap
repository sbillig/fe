use core::prelude::*
use std::prelude::*
use std::abi::sol::Uint160
use std::abi::sol::Int24

struct Swap {
    sender: Uint160,
    tick: Int24,
    amount: u256,
}

impl std::evm::Event for Swap {
    const TOPIC0: u256 = core::keccak(("Swap", "(", Uint160::SOL_TYPE, ",", Int24::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        let mut enc = std::abi::SolEncoder::new()
        let data_len = 0 + Int24::ENCODED_SIZE + u256::ENCODED_SIZE
        enc.reserve_head(data_len)
        (self.tick, self.amount).encode(mut enc)
        let (data_ptr, data_len) = enc.finish()
        log.log2(offset: data_ptr, len: data_len, topic0: Self::TOPIC0, topic1: self.sender.as_topic())
    }
}
