use core::prelude::*
use std::prelude::*
use std::evm::Address

pub struct Transfer {
    pub from: Address,
    pub to: Address,
    pub amount: u256,
}

impl std::evm::Event for Transfer {
    const TOPIC0: u256 = core::keccak(("Transfer", "(", Address::SOL_TYPE, ",", Address::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        let (data_ptr, data_len) = std::evm::encode_abi_payload(self.amount)
        log.log3(offset: data_ptr, len: data_len, topic0: Self::TOPIC0, topic1: self.from.as_topic(), topic2: self.to.as_topic())
    }
}
