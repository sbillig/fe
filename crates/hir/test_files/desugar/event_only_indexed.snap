use core::prelude::*
use std::prelude::*
use std::evm::Address

struct Approval {
    owner: Address,
    spender: Address,
    value: u256,
}

impl std::evm::Event for Approval {
    const TOPIC0: u256 = core::keccak(("Approval", "(", Address::SOL_TYPE, ",", Address::SOL_TYPE, ",", u256::SOL_TYPE, ")"))

    fn emit<L: std::evm::Log>(self, _ log: mut L) {
        log.log4(offset: 0, len: 0, topic0: Self::TOPIC0, topic1: self.owner.as_topic(), topic2: self.spender.as_topic(), topic3: self.value.as_topic())
    }
}
