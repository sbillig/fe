use core::prelude::*
use std::prelude::*
use std::evm::Address

struct Mixed {
    from: Address,
    flag: bool,
    value: i128,
}

impl std::evm::Event for Mixed {
    const TOPIC0: u256 = core::keccak(("Mixed", "(", Address::SOL_TYPE, ",", bool::SOL_TYPE, ",", i128::SOL_TYPE, ")"))

    fn emit<L: std::evm::Log>(own self, _ log: mut L) {
        let (data_ptr, data_len) = std::evm::encode_abi_payload((self.flag, self.value))
        log.log2(offset: data_ptr, len: data_len, topic0: Self::TOPIC0, topic1: self.from.as_topic())
    }
}
