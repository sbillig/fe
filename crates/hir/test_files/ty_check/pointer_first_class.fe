use core::ops::{Add, Sub}

struct Data {
    value: u256,
    other: u256,
}

fn pointer_casts_and_arithmetic(raw: u256, data: *Data, bytes: *u8) -> u256 {
    let typed_from_raw: *Data = raw as *Data
    let raw_again: u256 = typed_from_raw as u256
    let bytes_from_typed: *u8 = typed_from_raw as *u8
    let typed_again: *Data = bytes_from_typed as *Data
    let next: *Data = typed_again + 32
    let prev: *Data = next - 32
    let distance: u256 = next - typed_again
    let raw_bytes: *u8 = 0 as *u8

    raw_again + distance + (prev as u256) + (data as u256) + (bytes as u256) + (raw_bytes as u256)
}
