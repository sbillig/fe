fn borrow_handles_readback() -> u256:
  bb0:
    v0: u256 = 0
    v1: mut u256 = &mem[place_root(v0)]
    store mem[v1].* = 5
    v2: u256 = load mem[v1].*
    v3: u256 = checked_add<u256>(v2, 1)
    store mem[v1].* = v3
    v4: u256 = load mem[v1].*
    v5: u256 = checked_add<u256>(v4, 1)
    store mem[v1].* = v5
    v6: u256 = load mem[place_root(v0)]
    ret v6
