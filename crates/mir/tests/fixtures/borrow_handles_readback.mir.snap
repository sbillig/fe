fn borrow_handles_readback() -> u256:
  bb0:
    v5: u256 = alloc mem
    v0: u256 = 0
    store mem[place_root(v5)] = v0
    v1: mut u256 = &mem[place_root(v5)]
    store mem[v1].* = 5
    v2: u256 = load mem[v1].*
    store mem[v1].* = (v2 + 1)
    v3: u256 = load mem[v1].*
    store mem[v1].* = (v3 + 1)
    v4: u256 = load mem[place_root(v5)]
    ret v4
