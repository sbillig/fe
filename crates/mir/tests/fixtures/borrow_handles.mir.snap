fn borrow_handles() -> ():
  bb0:
    v4: u256 = alloc mem
    v0: u256 = 0
    store mem[place_root(v4)] = v0
    v1: mut u256 = &mem[place_root(v4)]
    store mem[v1].* = 1
    v2: u256 = load mem[v1].*
    v3: u256 = checked_add<u256>(v2, 1)
    store mem[v1].* = v3
    ret
