#![arithmetic(unchecked)]

use std::evm::effects::assert

#[test]
fn top_level_inner_attr_wraps_u8_add() {
    let x: u8 = 255
    let y: u8 = x + 1
    assert(y == 0)
}

#[arithmetic(checked)]
#[test(should_revert)]
fn function_override_restores_checked_add() {
    let x: u8 = 255
    let y: u8 = x + 1
}
