
#[test]
fn assignment_rhs_can_start_on_next_line() {
    let mut x: u256 = 1
    x =
        2
    assert!(x == 2)
}

#[test]
fn augmented_assignment_rhs_can_start_on_next_line() {
    let mut x: u256 = 1
    x +=
        2
    assert!(x == 3)
}

#[test]
fn binary_rhs_can_start_on_next_line() {
    let x: u256 =
        1 +
            2
    assert!(x == 3)
}
