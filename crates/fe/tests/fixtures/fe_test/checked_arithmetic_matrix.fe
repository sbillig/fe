// =====================================================================
// u256 / i256
// =====================================================================

#[test(should_revert)]
fn unsigned_add_overflow_u256() {
    let x: u256 = 115792089237316195423570985008687907853269984665640564039457584007913129639935
    let y: u256 = x + 1
}

#[test(should_revert)]
fn unsigned_sub_underflow_u256() {
    let a: u256 = 0
