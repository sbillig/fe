use core::ptr

/// Regression test: allocating a struct whose fields land at 0x80 must not
/// corrupt subsequent calls to ptr::alloc_bytes.  Previously, ptr::alloc_bytes read
/// mload(0x80) as a Sonatina stack-pointer guard even though 0x80 can hold
/// user data, causing wild pointer values.
struct Pair {
    a: Address,
    b: Address,
}

#[test]
fn test_alloc_after_struct() uses (evm: Evm) {
    let p = Pair {
        a: Address { inner: 0x1111111111111111111111111111111111111111 },
        b: Address { inner: 0x2222222222222222222222222222222222222222 },
    }

    // This calls ptr::alloc_bytes under the hood.  Before the fix it would use the
    // address value at 0x80 as a heap pointer and crash with OutOfGas.
    let ptr = ptr::alloc_bytes(32)

    // Sanity: the allocation should be usable, not a wild pointer derived from
    // the address value above.
    *ptr = 7
    assert!(*ptr == 7)

    // Verify original struct is intact.
    assert!(p.a.inner == 0x1111111111111111111111111111111111111111)
    assert!(p.b.inner == 0x2222222222222222222222222222222222222222)
}
