use std::evm::{Address, Call, Create, Evm, RawMem}
use std::evm::mem

msg CountMsg {
    #[selector = 0x01020304]
    Count -> u256,
}

msg ZeroSelectorMsg {
    #[selector = 0x00000000]
    Hit -> u256,
}

msg PrefixSelectorMsg {
    #[selector = 0xaa000000]
    Hit -> u256,
}

pub contract GuardedFallback {
    mut count: u256,

    recv {
        ZeroSelectorMsg::Hit {} -> u256 {
            100
        }

        PrefixSelectorMsg::Hit {} -> u256 {
            200
        }

        CountMsg::Count {} -> u256 uses (count) {
            count
        }

        _ uses (mut count) {
            count += 1
        }
    }
}

pub contract NoFallback {
    recv {
        ZeroSelectorMsg::Hit {} -> u256 {
            100
        }
    }
}

fn raw_call(addr: Address, gas: u256, value: u256, args_offset: u256, args_len: u256) -> bool
uses (evm: mut Evm)
{
    evm.raw_call(addr: addr, gas: gas, value: value, args_offset: args_offset, args_len: args_len)
}

#[test]
fn test_empty_calldata_uses_fallback_not_zero_selector() uses (evm: mut Evm) {
    let addr = evm.create2<GuardedFallback>(value: 0, args: (), salt: 0)
    assert!(raw_call(addr: addr, gas: 100000, value: 0, args_offset: 0, args_len: 0))

    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CountMsg::Count {})
    assert!(count == 1)
}

#[test]
fn test_short_prefix_calldata_uses_fallback_not_padded_selector() uses (evm: mut Evm) {
    let addr = evm.create2<GuardedFallback>(value: 0, args: (), salt: 0)
    let ptr = mem::alloc(1)
    evm.mstore8(addr: ptr, value: 0xaa)
    assert!(raw_call(addr: addr, gas: 100000, value: 0, args_offset: ptr, args_len: 1))

    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CountMsg::Count {})
    assert!(count == 1)
}

#[test]
fn test_full_zero_selector_still_dispatches() uses (evm: mut Evm) {
    let addr = evm.create2<GuardedFallback>(value: 0, args: (), salt: 0)
    let result: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: ZeroSelectorMsg::Hit {})
    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CountMsg::Count {})

    assert!(result == 100)
    assert!(count == 0)
}

#[test]
fn test_empty_calldata_without_fallback_reverts() uses (evm: mut Evm) {
    let addr = evm.create2<NoFallback>(value: 0, args: (), salt: 0)
    assert!(!raw_call(addr: addr, gas: 100000, value: 0, args_offset: 0, args_len: 0))
}
