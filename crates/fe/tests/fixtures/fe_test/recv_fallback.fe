use std::evm::{Address, Call, Create, Evm, RawMem}
use std::evm::mem

msg CounterMsg {
    #[selector = 0x01020304]
    Ping -> u256,
    #[selector = 0x01020305]
    Count -> u256,
}

msg UnknownSelectorMsg {
    #[selector = 0xdeadbeef]
    Trigger { value: u256 },
}

pub contract Counter {
    count: u256,

    recv {
        CounterMsg::Ping {} -> u256 {
            7
        }

        CounterMsg::Count {} -> u256 uses (count) {
            count
        }

        _ uses (mut count) {
            count += 1
        }
    }
}

fn raw_call(addr: Address, gas: u256, value: u256, args_offset: u256, args_len: u256) -> bool
uses (evm: mut Evm)
{
    evm.raw_call(addr: addr, gas: gas, value: value, args_offset: args_offset, args_len: args_len)
}

#[test]
fn test_known_selector_skips_fallback() uses (evm: mut Evm) {
    let addr = evm.create2<Counter>(value: 0, args: (), salt: 0)
    let result: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CounterMsg::Ping {})
    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CounterMsg::Count {})
    assert(result == 7)
    assert(count == 0)
}

#[test]
fn test_unknown_selector_hits_fallback() uses (evm: mut Evm) {
    let addr = evm.create2<Counter>(value: 0, args: (), salt: 0)
    evm.call(
        addr: addr,
        gas: 100000,
        value: 0,
        message: UnknownSelectorMsg::Trigger { value: 7 },
    )

    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CounterMsg::Count {})
    assert(count == 1)
}

#[test]
fn test_short_calldata_hits_fallback() uses (evm: mut Evm) {
    let addr = evm.create2<Counter>(value: 0, args: (), salt: 0)
    let ptr = mem::alloc(1)
    evm.mstore8(addr: ptr, value: 0xaa)
    assert(raw_call(addr: addr, gas: 100000, value: 0, args_offset: ptr, args_len: 1))

    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CounterMsg::Count {})
    assert(count == 1)
}

#[test(balance = 1000000000)]
fn test_nonpayable_fallback_rejects_value() uses (evm: mut Evm) {
    let addr = evm.create2<Counter>(value: 0, args: (), salt: 0)
    let ptr = mem::alloc(1)
    evm.mstore8(addr: ptr, value: 0xaa)
    assert(!raw_call(addr: addr, gas: 100000, value: 1, args_offset: ptr, args_len: 1))

    let count: u256 = evm.call(addr: addr, gas: 100000, value: 0, message: CounterMsg::Count {})
    assert(count == 0)
}
