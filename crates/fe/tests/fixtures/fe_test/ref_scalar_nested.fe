struct Slot {
    value: u256,
}

struct Reader {
    source: ref Slot,
    bias: u256,
}

fn sum_reader(_ r: ref Reader) -> u256 {
    let mut total = 0
    let mut i: u256 = 0
    while i < 4 {
        total += r.source.value + r.bias
        i += 1
    }
    total
}

#[test]
fn test_ref_scalar_nested() {
    let slot = Slot { value: 7 }
    let reader = Reader {
        source: ref slot,
        bias: 3,
    }

    assert(sum_reader(ref reader) == 40)
}
