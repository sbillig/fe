use std::evm::effects::assert

const VALUES: [u256; 8] = [3, 1, 4, 1, 5, 9, 2, 6]
const PICKS: [usize; 4] = [4, 7, 2, 0]

fn pick(_ arr: [u256; 8], _ idx: usize) -> u256 {
    arr[idx]
}

fn tail_sum(_ arr: [u256; 8]) -> u256 {
    let mut sum: u256 = 0
    for i in 4..8 {
        sum += arr[i]
    }
    sum
}

#[test]
fn test_const_array_alias_reads() {
    let values: [u256; 8] = VALUES
    assert(values[0] == 3)
    assert(values[2] == 4)
    assert(values[5] == 9)
    assert(values[PICKS[1]] == 6)
}

#[test]
fn test_const_array_helper_calls() {
    let values: [u256; 8] = VALUES
    assert(pick(values, PICKS[0]) == 5)
    assert(tail_sum(VALUES) == 22)
}
