use std::evm::effects::assert
use core::ops::{SaturatingAdd, SaturatingMul, SaturatingSub}

#[test]
fn saturating_u8() {
    let max: u8 = 255
    let zero: u8 = 0
    assert(max.saturating_add(1) == max)
    assert(zero.saturating_sub(1) == zero)
    assert(max.saturating_mul(2) == max)
}

#[test]
fn saturating_u16() {
    let max: u16 = 65535
    let zero: u16 = 0
    assert(max.saturating_add(1) == max)
    assert(zero.saturating_sub(1) == zero)
    assert(max.saturating_mul(2) == max)
}

#[test]
fn saturating_u32() {
    let max: u32 = 4294967295
    let zero: u32 = 0
    assert(max.saturating_add(1) == max)
