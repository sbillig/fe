#[test]
fn saturating_i8() {
    let max: i8 = 127
    let min: i8 = -128
    assert(max.saturating_add(1) == max)
    assert(min.saturating_sub(1) == min)
    assert(max.saturating_mul(2) == max)
}

#[test]
fn saturating_i16() {
    let max: i16 = 32767
