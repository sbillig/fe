use core::ops::Index

struct WordView { base: u256 }

impl Copy for WordView {}

impl Index<u256> for WordView {
    type Output = u256

    fn index(self, _ offset: u256) -> u256 {
        self.base + offset
    }
}

#[test]
fn custom_index_reads_lower_as_trait_call() {
    let view = WordView { base: 7 }

    assert!(view[4] == 11)
    assert!(view[36] == 43)
}

#[test]
fn array_index_remains_place_projection() {
    let mut values: [u256; 2] = [1, 2]

    assert!(values[1] == 2)
    values[1] = 3
    assert!(values[1] == 3)
}
