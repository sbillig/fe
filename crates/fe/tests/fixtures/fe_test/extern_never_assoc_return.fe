
extern {
    fn todo() -> !
}

trait HasAssoc {
    type Assoc
}

struct Generic<T> {
    value: T,
}

impl<T> HasAssoc for Generic<T> {
    type Assoc = T
}

fn make<T: HasAssoc>() -> T::Assoc {
    todo()
}

fn trigger() {
    let _x: u32 = make<Generic<u32>>()
}

#[test]
fn test_extern_never_assoc_return_compiles() {
    assert!(true)
}
