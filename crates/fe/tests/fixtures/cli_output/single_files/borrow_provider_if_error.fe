msg Msg {
    #[selector = 1]
    Test -> u256,
}

pub contract C {
    mut value: u256,

    recv Msg {
        Test -> u256 uses (mut value) {
            let mut local = 1
            let pick = true
            let target: mut u256 = if pick { mut value } else { mut local }
            target += 1
            0
        }
    }
}
