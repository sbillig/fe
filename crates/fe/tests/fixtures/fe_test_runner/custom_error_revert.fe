#[error]
pub struct InsufficientBalance {
    pub balance: u256,
    pub required: u256,
}

// --- should_revert (any) ---

#[test(should_revert)]
fn test_revert_error_any() uses (evm: mut Evm) {
    revert_error(InsufficientBalance { balance: 100, required: 200 })
}

// --- should_revert with selector ---

#[test(should_revert, selector = 0x4e487b71)]
fn test_revert_panic_selector() uses (evm: mut Evm) {
    revert_error(Panic { code: 0x11 })
}

// --- should_revert with panic code ---

#[test(should_revert, panic = 0x11)]
fn test_revert_panic_overflow() uses (evm: mut Evm) {
    revert_error(Panic { code: 0x11 })
}

#[test(should_revert, panic = 0x12)]
fn test_revert_panic_division_by_zero() uses (evm: mut Evm) {
    revert_error(Panic { code: 0x12 })
}

#[test(should_revert, panic = 0x01)]
fn test_revert_panic_assert() uses (evm: mut Evm) {
    revert_error(Panic { code: 0x01 })
}

// --- assert!() now emits Panic(0x01) ---

#[test(should_revert, panic = 0x01)]
fn test_assert_emits_panic() uses (evm: mut Evm) {
    assert!(false)
}

// --- unwrap() on Result<ErrorVariant, T> emits selector ---

fn fallible_panic() -> Result<Panic, u256> {
    Err(Panic { code: 0x11 })
}

#[test(should_revert, panic = 0x11)]
fn test_unwrap_error_variant_emits_selector() uses (evm: mut Evm) {
    let result = fallible_panic()
    result.unwrap()
}

fn fallible_custom() -> Result<InsufficientBalance, u256> {
    Err(InsufficientBalance { balance: 100, required: 200 })
}

// selector for InsufficientBalance(uint256,uint256) = 0xcf479181
#[test(should_revert, selector = 0xcf479181)]
fn test_unwrap_custom_error_emits_selector() uses (evm: mut Evm) {
    let result = fallible_custom()
    result.unwrap()
}
