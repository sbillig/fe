use std::evm::{MemoryBytes, RawMem}
use std::evm::mem

#[test]
fn test_dynamic_array_payload_end_uses_max_element_end() uses (raw: mut RawMem) {
    // bytes[] payload:
    //   len = 2
    //   offset0 = 64, offset1 = 96
    //   element0 len = 96, element1 len = 0
    //
    // The offsets are monotonic, but element0 extends past element1.
    let ptr = mem::alloc(224)
    raw.mstore(addr: ptr, value: 2)
    raw.mstore(addr: ptr + 32, value: 64)
    raw.mstore(addr: ptr + 64, value: 96)
    raw.mstore(addr: ptr + 96, value: 96)
    raw.mstore(addr: ptr + 128, value: 0)
    raw.mstore(addr: ptr + 160, value: 0)
    raw.mstore(addr: ptr + 192, value: 0)

    let input = MemoryBytes::new(base: ptr, len: 224)
    let decoded: Vec<Bytes> = input.decode()

    assert(decoded.len() == 2)
    assert(decoded.size == 224)
}
