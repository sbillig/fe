#[test(should_revert)]
fn test_const_oob_read_reverts() {
    let arr: [u256; 2] = [10, 20]
    let val = arr[2]
}

#[test(should_revert)]
fn test_const_oob_write_reverts() {
    let mut arr: [u256; 2] = [10, 20]
    arr[2] = 99
}

#[test(should_revert)]
fn test_const_oob_dead_read_reverts() {
    let arr: [u256; 2] = [10, 20]
    let _val = arr[2]
}
