trait BoundConst {
    type X
    const C: Self::X
}

struct Slot<const N: u32> {}

fn use_in_type<T: BoundConst<X = u32>>(_ slot: Slot<{ T::C }>) {}

// KNOWN GAP: the declared type of `T::C` (`Self::X`) is not normalized under
// the bound's assoc-type binding `X = u32`, so the const arg mis-types.
