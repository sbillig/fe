trait SuperMethod {
    fn run(self)
}

trait ChildMethod: SuperMethod {}

struct BadMethod {}

impl SuperMethod for BadMethod {}

impl ChildMethod for BadMethod {}

fn needs_child_method<T: ChildMethod>(_value: T) {}

fn use_child_method(value: BadMethod) {
    needs_child_method(value)
}

