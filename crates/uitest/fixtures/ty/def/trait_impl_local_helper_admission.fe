    const N: u32 = 1
}

impl UsesLenMethod for LenMethodStruct {
    fn buf(self) -> [u8; 1] {
        [0]
    }
}

fn needs_uses_len_method<T: UsesLenMethod>(_value: T) {}

fn use_len_method(value: LenMethodStruct) {
    needs_uses_len_method(value)
}

