struct Byte<const N: u8> {}

const NOT: u8 = ~0

type ShlArr = [u8; 1 << 3]
type ShrArr = [u8; 8 >> 1]
type AndArr = [u8; 6 & 3]
type OrArr = [u8; 4 | 2]
type XorArr = [u8; 5 ^ 1]
type NotByte = Byte<NOT>

fn takes_shl(_: ShlArr) {}
fn takes_shr(_: ShrArr) {}
fn takes_and(_: AndArr) {}
fn takes_or(_: OrArr) {}
fn takes_xor(_: XorArr) {}
fn takes_not(_: NotByte) {}

fn ok(a: ShlArr, b: ShrArr, c: AndArr, d: OrArr, e: XorArr, f: NotByte) {
    takes_shl(a)
    takes_shr(b)
    takes_and(c)
    takes_or(d)
    takes_xor(e)
    takes_not(f)
}
