fn wrong_arity_zero() {
    assert!()
}

fn wrong_arity_three() {
    assert!(true, "boom", "extra")
}

fn non_literal_message() {
    let message = "boom"
    assert!(true, message)
}

fn wrong_condition_type() {
    assert!(1, "boom")
}

fn old_assert_spelling_is_not_builtin() {
    assert_msg(false, "boom")
}
