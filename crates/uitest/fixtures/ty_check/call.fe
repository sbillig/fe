pub fn add(x: i32, y: i32) -> i32 {
    x + y
}

pub fn use_add() -> i32 {
    add(1, 2)
    let x = 1
    let y = 2
    add(x, y)
    add(y: 1, x: 2)
    add(x: 1, z: 2)
    add(x: false, y: 2)
}

pub fn make_tuple<T, U>(_ t: own T, _ u: own U) -> (T, U) {
    (t, u)
}

pub fn use_make_tuple() -> (i32, u32) {
    make_tuple<i32, u32>(false, 1)
}

fn f() {
    let x: u32 = 1
    x(100)
}
