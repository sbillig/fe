use stuff::calculations::{ return_three, return_four }
use stuff::calculations::ambiguous
use stuff::Color

/// ## `return_seven`
/// ### a function of numbers
/// #### returns the 3+4=7
pub fn return_seven() {
  return_three() + return_four()
}

fn calculate() {
  return_seven()
  let x: stuff::calculations::ambiguous
}

/// Anything that can be calculated ought to implement a
/// `calculate` function
pub trait Calculatable {
  fn calculate(self) -> i32
}

/// A struct for holding numbers like `x` and `y`
struct Numbers {
  x: i32,
  y: i32
}

fn add(x: i32, y: i32) -> i32 {
    x + y
}

impl Calculatable for Numbers {
  fn calculate(self) -> i32 {
      let z = self.x
      let w = self.y
      add(z, w)
  }
}

enum Option {
  Some(i32),
  None
}

/// Test local variable scoping and shadowing
fn test_locals(x: i32) -> i32 {
  let a = x
  let x = a + 1
  {
    let x = x + 1
    x
  }
}

/// Test match arm bindings
fn test_match(opt: Option) -> i32 {
  match opt {
    Option::Some(val) => val
    Option::None => 0
  }
}

fn favorite_color() -> Color {
  Color::Red
}

fn describe_color(c: Color) -> i32 {
  match c {
    Color::Red => 1
    Color::Green => 2
    Color::Blue => 3
  }
}

struct Wrapper<T> {
  inner: T
}

fn wrap<T>(val: T) -> Wrapper<T> {
  Wrapper { inner: val }
}

fn unwrap_numbers(w: Wrapper<Numbers>) -> i32 {
  w.inner.x
}

fn do_calc<T: Calculatable>(thing: T) -> i32 {
  thing.calculate()
}

msg TokenMsg {
  #[selector = 0x01]
  Mint { to: i32, amount: i32 } -> bool,
  #[selector = 0x02]
  Burn { amount: i32 } -> bool,
}

pub contract Token {
  mut supply: i32

  recv TokenMsg {
    Mint { to, amount } -> bool uses (mut supply) {
      supply += amount
      true
    }
    Burn { amount } -> bool uses (mut supply) {
      supply -= amount
      true
    }
  }
}
