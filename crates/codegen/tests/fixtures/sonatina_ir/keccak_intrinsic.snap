---
source: crates/codegen/tests/sonatina_ir.rs
expression: output
input_file: crates/codegen/tests/fixtures/keccak_intrinsic.fe
---
target = "evm-ethereum-osaka"

func private %hash(v0.i256, v1.i256) -> i256 {
    block0:
        jump block1;

    block1:
        v4.i256 = call %keccak256 v0 v1;
        return v4;
}

func private %keccak256(v0.i256, v1.i256) -> i256 {
    block0:
        jump block1;

    block1:
        v4.i256 = evm_keccak256 v0 v1;
        return v4;
}

func private %main() -> i256 {
    block0:
        jump block1;

    block1:
        v2.i256 = call %hash 0.i256 32.i256;
        return v2;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %main;
        evm_stop;
}


object @main {
    section main {
        entry %main_root;
    }
}
