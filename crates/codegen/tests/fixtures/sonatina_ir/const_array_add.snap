---
source: crates/codegen/tests/sonatina_ir.rs
expression: output
input_file: crates/codegen/tests/fixtures/const_array_add.fe
---
target = "evm-ethereum-osaka"

global private const [i256; 3] $const_region_0 = [10, 20, 30];

func private %get_sum() -> i256 {
    block0:
        jump block1;

    block1:
        v1.constref<[i256; 3]> = const.ref $const_region_0;
        return 11.i256;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %get_sum;
        evm_stop;
}


object @main {
    section main {
        entry %main_root;
        data $const_region_0;
    }
}
