---
source: crates/codegen/tests/sonatina_ir.rs
expression: output
input_file: crates/codegen/tests/fixtures/borrow_handles_readback.fe
---
target = "evm-ethereum-osaka"

func private %__fe_main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %borrow_handles_readback;
        evm_stop;
}

func private %borrow_handles_readback() -> i256 {
    block0:
        v0.*i256 = alloca i256;
        jump block1;

    block1:
        mstore v0 0.i256 i256;
        v2.i256 = ptr_to_int v0 i256;
        mstore v2 5.i256 i256;
        v4.i256 = mload v0 i256;
        return v4;
}


object @main {
    section main {
        entry %__fe_main_root;
    }
}
