}

func private %if_else(v0.i1) -> i64 {
    block0:
        jump block1;

    block1:
        br v0 block2 block3;

    block2:
        v3.i64 = call %helper 1.i64;
        jump block4;

    block3:
        v5.i64 = call %helper 2.i64;
        jump block4;

    block4:
        v6.i64 = phi (v3 block2) (v5 block3);
        return v6;
}

func private %main() -> i64 {
    block0:
        jump block1;

    block1:
        v1.i64 = call %if_else 1.i1;
        return v1;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i64 = call %main;
        evm_stop;
}


object @main {
