---
source: crates/codegen/tests/sonatina_ir.rs
expression: output
input_file: crates/codegen/tests/fixtures/const_array_branch.fe
---
target = "evm-ethereum-osaka"

global private const [i256; 1] $const_region_0 = [1];

func private %const_array_branch(v0.i1) -> i256 {
    block0:
        jump block1;

    block1:
        br v0 block2 block3;

    block2:
        v2.constref<[i256; 1]> = const.ref $const_region_0;
        jump block4;

    block3:
        v5.constref<[i256; 1]> = const.ref $const_region_0;
        jump block4;

    block4:
        return 1.i256;
}

func private %main() -> i256 {
    block0:
        jump block1;

    block1:
        v1.i256 = call %const_array_branch 1.i1;
        return v1;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %main;
        evm_stop;
}


object @main {
    section main {
        entry %main_root;
    }
}
