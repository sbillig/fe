---
source: crates/codegen/tests/sonatina_ir.rs
expression: output
input_file: crates/codegen/tests/fixtures/match_mixed_return.fe
---
target = "evm-ethereum-osaka"

type @layout_0 = enum {
    #A,
    #B,
};

func private %f(v0.@layout_0) -> i256 {
    block0:
        jump block1;

    block1:
        v2.enumtag(@layout_0) = enum.tag v0;
        br_table v2 (0.enumtag(@layout_0) block3) (1.enumtag(@layout_0) block4);

    block2:
        return 2.i256;

    block3:
        return 0.i256;

    block4:
        jump block2;
}

func private %main() -> i256 {
    block0:
        jump block1;

    block1:
        v0.@layout_0 = enum.make @layout_0 #B;
        v1.i256 = call %f v0;
        return v1;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %main;
        evm_stop;
}


object @main {
    section main {
        entry %main_root;
    }
}
