    block5:
        v7.*i256 = int_to_ptr v0 *i256;
        v8.i256 = mload v7 i256;
        br_table v8 block4 (0.i256 block1) (1.i256 block3);
}

func private %__fe_sonatina_entry() {
    block0:
        v1.i8 = call %match_with_wildcard 0.i256;
