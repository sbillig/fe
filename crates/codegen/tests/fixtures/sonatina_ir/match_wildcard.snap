func private %multiple_before_wildcard(v0.i256) -> i8 {
    block0:
        jump block5;

    block1:
        jump block2;

    block2:
        v3.i8 = phi (1.i8 block1) (2.i8 block3) (3.i8 block4);
        return v3;

    block3:
        jump block2;

    block4:
