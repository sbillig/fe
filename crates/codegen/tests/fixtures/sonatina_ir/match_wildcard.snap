        jump block4;

    block1:
        jump block2;

    block2:
        v3.i8 = phi (1.i8 block1) (0.i8 block3);
        return v3;

    block3:
        jump block2;

    block4:
        v5.*i256 = int_to_ptr v0 *i256;
        v6.i256 = mload v5 i256;
        br_table v6 block3 (0.i256 block1);
}

