        v26.i8 = mload v5 i8;
        v27.i1 = ne v25 0.i8;
        v28.i1 = ne v26 0.i8;
        v29.i1 = eq v27 v28;
        mstore v6 v29 i1;
        v30.i1 = mload v6 i1;
        br v30 block3 block6;

    block6:
        jump block4;
}


object @main {
    section main {
        entry %__fe_main_root;
    }
}
