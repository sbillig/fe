        embed .runtime as &__Child_runtime;
    }
    section runtime {
        entry %__Child_runtime;
    }
}

object @Parent {
    section init {
        entry %__Parent_init;
        embed @Child.init as &__Child_init;
        embed .runtime as &__Parent_runtime;
    }
    section runtime {
        entry %__Parent_runtime;
    }
}
