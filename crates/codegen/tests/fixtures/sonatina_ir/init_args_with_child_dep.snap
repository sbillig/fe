object @Parent {
    section init {
        entry %__fe_contract_init_root_Parent;
        embed @Child.init as &Child_init;
        embed .runtime as &Parent_runtime;
    }
    section runtime {
        entry %__fe_contract_runtime_root_Parent;
    }
}
