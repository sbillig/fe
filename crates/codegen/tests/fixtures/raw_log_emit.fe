use core::{EffectHandle, ptr}
use std::evm::{Evm, Log, MemPtr, RawMem}

struct Data {
    a: u256,
}

fn raw_emit(evm: mut Evm) {
    let data: MemPtr<Data> = evm.mem_ptr(ptr::alloc<Data>())
    evm.log0(offset: ptr::as_bytes(data.raw()), len: core::size_of<Data>())
}

pub fn main() uses (evm: mut Evm) {
    raw_emit(mut evm)
}
