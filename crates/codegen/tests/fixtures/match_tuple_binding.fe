// Test tuple pattern matching WITH variable bindings
// This exercises decision tree leaf.bindings for tuple elements

pub fn match_tuple_extract(t: own (u8, u8)) -> u8 {
    match t {
        (0, y) => y,
        (x, 0) => x,
        (a, b) => a + b,
    }
}

pub fn match_nested_extract(t: own ((u8, u8), u8)) -> u8 {
    match t {
        ((0, 0), z) => z,
        ((x, y), 0) => x + y,
        ((a, _), c) => a + c,
    }
}

pub fn main() -> (u8, u8) {
    (
        match_tuple_extract((1, 2)),
        match_nested_extract(((1, 2), 3)),
    )
}
