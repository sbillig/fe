      }
      function $shr($self, $other) -> ret {
        let r0 := mload(0x40)
        if iszero(r0) {
          r0 := 0x80
        }
        mstore(0x40, add(r0, 32))
        let r1 := mload(0x40)
        if iszero(r1) {
          r1 := 0x80
        }
        mstore(0x40, add(r1, 32))
        let r2 := mload(0x40)
        if iszero(r2) {
          r2 := 0x80
        }
        mstore(0x40, add(r2, 32))
        let v3 := 0
        mstore(r0, $self)
        mstore(r1, $other)
        v3 := shr(mload(r1), mload(r0))
        mstore(r2, v3)
        ret := mload(r2)
        leave
      }
      $runtime()
    }
  }
}
