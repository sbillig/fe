impl<A: Abi> Decode<A> for Bytes {
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let tail_rel = d.read_word()
        let tail_at = d.base() + tail_rel
        let data_len = d.peek_word(tail_at)
        let payload_size = 32 + round_up_words(data_len)
        let data_ptr = d.alloc(payload_size)

        let mut offset: u256 = 0
        while offset < payload_size {
            A::store_word(data_ptr + offset, d.peek_word(tail_at + offset))
            offset += 32
        }

        Bytes {
            data: data_ptr,
            len: data_len,
            size: payload_size,
        }
    }
}

impl<A: Abi> Encode<A> for Bytes {
    const DIRECT_ENCODE: bool = false

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let tail_at = e.append_tail(self.size)
        let offset = tail_at - e.base()

        e.write_word(offset)
        if self.data == 0 {
            e.write_word_at(tail_at, self.len)
            return
        }

        let mut offset_in_payload: u256 = 0
        while offset_in_payload < self.size {
            e.write_word_at(
                tail_at + offset_in_payload,
                mem_word_at(self.data, offset_in_payload),
            )
            offset_in_payload += 32
        }
    }

    fn encode_to_ptr(own self, ptr: u256) {
        super::panic()
    }
}

fn dyn_array_payload_end<A: Abi, T, I>(input: I, tail_at: u256, elem_count: u256) -> u256
    where T: AbiSpan<A> + AbiSize,
          I: ByteInput
{
    let elems_base = tail_at + 32
    let mut head_pos = elems_base
    let mut end = elems_base + (elem_count * abi_slot_size<T>())
    let mut i: u256 = 0
    while i < elem_count {
        end = max_u256(end, abi_field_end<A, T, I>(input, elems_base, head_pos))
        head_pos += abi_slot_size<T>()
        i += 1
    }
    end
}

impl<A: Abi, T> Decode<A> for DynArray<T>
    where T: AbiSpan<A> + AbiSize
{
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let tail_rel = d.read_word()
        let tail_at = d.base() + tail_rel
        let elem_count = d.peek_word(tail_at)
        let payload_end = dyn_array_payload_end<A, T, D::Input>(d.input(), tail_at, elem_count)
        let payload_size = payload_end - tail_at
        let data_ptr = d.alloc(payload_size)

        let mut offset: u256 = 0
        while offset < payload_size {
            A::store_word(data_ptr + offset, d.peek_word(tail_at + offset))
            offset += 32
        }

        DynArray {
            data: data_ptr,
            len: elem_count,
            size: payload_size,
        }
    }
}

impl<A: Abi, T> Encode<A> for DynArray<T>
    where T: AbiSize
{
    const DIRECT_ENCODE: bool = false

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let tail_at = e.append_tail(self.size)
        let offset = tail_at - e.base()

        e.write_word(offset)
        if self.data == 0 {
            e.write_word_at(tail_at, self.len)
            return
        }

        let mut offset_in_payload: u256 = 0
        while offset_in_payload < self.size {
            e.write_word_at(
                tail_at + offset_in_payload,
                mem_word_at(self.data, offset_in_payload),
            )
            offset_in_payload += 32
        }
    }

    fn encode_to_ptr(own self, ptr: u256) {
        super::panic()
    }
}

impl<A: Abi, T> AbiSpan<A> for DynArray<T>
    where T: AbiSpan<A> + AbiSize
{
    fn abi_end<I: ByteInput>(input: I, base: u256, pos: u256) -> u256 {
        let tail_rel = input.word_at(pos)
        let tail_at = base + tail_rel
        let elem_count = input.word_at(tail_at)
        dyn_array_payload_end<A, T, I>(input, tail_at, elem_count)
    }
}

