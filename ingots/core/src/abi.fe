use ingot::Copy
use ingot::EffectHandle
use ingot::MemPtr
use ingot::num::IntDowncast

/// Errors returned by ABI decoding/encoding helpers.
pub enum AbiError {
    InputTooShort,
    OutOfBounds,
    InvalidSelector,
    InvalidOffset,
    NonCanonical,
    InvalidBool,
    InvalidUtf8,
    LengthOverflow,
    AllocationFailed,
}

/// Generic read-only byte input for ABI decoding.
///
/// Implementations may return padded values (e.g. EVM calldata loads) so callers
/// must use `len()` to enforce bounds/canonicality.
pub trait ByteInput: Copy {
    fn len(self) -> u256
    fn word_at(self, byte_offset: u256) -> u256
    fn byte_at(self, byte_offset: u256) -> u8
}

/// First-word prefix used for fast dispatch.
pub struct Prefix {
    pub len: u256,
    pub word0: u256,
}

pub fn prefix<I: ByteInput>(input: I) -> Prefix {
    Prefix {
        len: input.len(),
        word0: input.word_at(0),
    }
}

/// Generic cursor over a `ByteInput`.
pub struct Cursor<I> {
    pub input: I,
    pub pos: u256,
}

impl<I> Cursor<I>
    where I: ByteInput
{
    pub fn new(input: own I) -> Self {
        Cursor {
            input,
            pos: 0,
        }
    }

    pub fn fork(self, pos: u256) -> Self {
        Cursor {
            input: self.input,
            pos,
        }
    }

    #[arithmetic(unchecked)]
    pub fn read_u8(mut self) -> u8 {
        let b = self.input.byte_at(self.pos)
        self.pos = self.pos + 1
        b
    }

    #[arithmetic(unchecked)]
    pub fn read_word(mut self) -> u256 {
        let w = self.input.word_at(self.pos)
        self.pos = self.pos + 32
        w
    }

    pub fn peek_word(self, at: u256) -> u256 {
        self.input.word_at(at)
    }
}

/// ABI definition (selector width/format).
pub trait Abi {
    type Selector
    /// Higher-kinded type constructor for a decoder over some `ByteInput`.
    type Decoder: * -> *
    /// ABI encoder type.
    type Encoder: AbiEncoder<Self>

    /// Size of the selector in bytes.
    const SELECTOR_SIZE: u256

    fn selector_from_prefix(_: u256) -> Self::Selector

    fn decode_bool_word(_: u256) -> bool
    fn decode_u8_word(_: u256) -> u8
    fn decode_u16_word(_: u256) -> u16
    fn decode_u32_word(_: u256) -> u32
    fn decode_u64_word(_: u256) -> u64
    fn decode_u128_word(_: u256) -> u128
    fn decode_i8_word(_: u256) -> i8
    fn decode_i16_word(_: u256) -> i16
    fn decode_i32_word(_: u256) -> i32
    fn decode_i64_word(_: u256) -> i64
    fn decode_i128_word(_: u256) -> i128

    fn decoder_new<I: ByteInput>(_: own I) -> Self::Decoder<I>
    fn decoder_with_base<I: ByteInput>(_: own I, base: u256) -> Self::Decoder<I>

    fn encoder_new() -> Self::Encoder
    fn store_word(ptr: u256, value: u256)
}

/// ABI decoder with cursor state and an allocation hook.
pub trait AbiDecoder<A: Abi> {
    type Input: ByteInput

    fn input(self) -> Self::Input
    fn base(self) -> u256
    fn set_base(mut self, new_base: u256)
    fn pos(self) -> u256
    fn set_pos(mut self, new_pos: u256)

    fn read_u8(mut self) -> u8
    fn read_word(mut self) -> u256
    fn peek_word(self, at: u256) -> u256

    fn alloc(mut self, size: u256) -> u256
}

/// ABI encoder with cursor state and dynamic tail allocation.
pub trait AbiEncoder<A: Abi> {
    fn base(self) -> u256
    fn set_base(mut self, new_base: u256)
    fn pos(self) -> u256
    fn set_pos(mut self, new_pos: u256)

    fn write_u8(mut self, v: u8)
    fn write_word(mut self, v: u256)
    fn write_word_at(mut self, at: u256, v: u256)

    fn reserve_head(mut self, bytes: u256) -> u256
    fn append_tail(mut self, bytes: u256) -> u256

    fn finish(self) -> (u256, u256)
}

/// ABI static encoded size in bytes.
///
/// This is the fixed (compile-time) encoded size for a type under Fe's ABI model.
pub trait AbiSize {
    const ENCODED_SIZE: u256
    const IS_DYNAMIC: bool
    const NEEDS_PARENT_WRAPPER: bool
}

pub trait AbiSpan<A: Abi>: AbiSize {
    fn abi_end<I: ByteInput>(input: I, base: u256, pos: u256) -> u256
}

pub trait Decode<A: Abi> {
    fn decode<D: AbiDecoder<A>>(_: mut D) -> Self
}

pub trait Encode<A: Abi>: AbiSize {
    const DIRECT_ENCODE: bool

    fn encode<E: AbiEncoder<A>>(own self, _: mut E)
    fn encode_to_ptr(own self, ptr: u256)
}

pub fn decode_or_revert<A: Abi, T, D>(d: mut D) -> T
    where T: Decode<A>, D: AbiDecoder<A>
{
    T::decode(d)
}

pub const fn abi_slot_size<T: AbiSize>() -> u256 {
    if T::IS_DYNAMIC {
        return 32
    }
    T::ENCODED_SIZE
}

pub const fn abi_root_head_size<T: AbiSize>() -> u256 {
    if T::NEEDS_PARENT_WRAPPER {
        return 32
    }
    T::ENCODED_SIZE
}

pub fn decode_root<A: Abi, T, D>(d: mut D) -> T
    where T: Decode<A> + AbiSize,
          D: AbiDecoder<A>
{
    if T::NEEDS_PARENT_WRAPPER {
        return decode_field<A, T, D>(mut d)
    }

    T::decode(d)
}

pub fn decode_field<A: Abi, T, D>(d: mut D) -> T
    where T: Decode<A> + AbiSize,
          D: AbiDecoder<A>
{
    if T::NEEDS_PARENT_WRAPPER {
        let tail_rel = d.read_word()
        let parent_base = d.base()
        let parent_pos = d.pos()
        d.set_base(parent_base + tail_rel)
        d.set_pos(d.base())
        let value = T::decode(mut d)
        d.set_base(parent_base)
        d.set_pos(parent_pos)
        return value
    }

    T::decode(d)
}

fn decode_field_at<A: Abi, T, D>(d: mut D, pos: u256) -> T
    where T: Decode<A> + AbiSize,
          D: AbiDecoder<A>
{
    d.set_pos(pos)
    decode_field<A, T, D>(mut d)
}

pub fn encode_root<A: Abi, T, E>(value: own T, e: mut E)
    where T: Encode<A> + AbiSize, E: AbiEncoder<A>
{
    if T::NEEDS_PARENT_WRAPPER {
        encode_field<A, T, E>(value, mut e)
        return
    }

    value.encode(mut e)
}

pub fn encode_field<A: Abi, T, E>(value: own T, e: mut E)
    where T: Encode<A> + AbiSize, E: AbiEncoder<A>
{
    if T::NEEDS_PARENT_WRAPPER {
        let parent_base = e.base()
        let child_base = e.append_tail(T::ENCODED_SIZE)
        e.write_word(child_base - parent_base)
        let parent_pos = e.pos()

        e.set_base(child_base)
        e.set_pos(child_base)
        value.encode(mut e)
        e.set_base(parent_base)
        e.set_pos(parent_pos)
        return
    }

    value.encode(mut e)
}

fn max_u256(a: u256, b: u256) -> u256 {
    if a >= b {
        a
    } else {
        b
    }
}

pub fn abi_field_end<A: Abi, T, I>(input: I, base: u256, pos: u256) -> u256
    where T: AbiSpan<A> + AbiSize,
          I: ByteInput
{
    if T::NEEDS_PARENT_WRAPPER {
        let tail_rel = input.word_at(pos)
        let tail_at = base + tail_rel
        return T::abi_end(input, tail_at, tail_at)
    }

    T::abi_end(input, base, pos)
}

fn round_up_words(len: u256) -> u256 {
    if len == 0 {
        return 0
    }
    (((len - 1) / 32) + 1) * 32
}

// Fe strings are currently represented as a single packed word. This limits the
// ABI path here to strings whose runtime payload fits in 32 bytes.
fn packed_string_len(word: u256) -> u256 {
    let mut len: u256 = 0
    let mut value = word
    while value != 0 {
        len += 1
        value = value >> 8
    }
    len
}

pub struct BytesView<I> {
    pub input: I,
    pub start: u256,
    pub len: u256,
}

impl<I> BytesView<I>
    where I: ByteInput
{
    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }

    #[arithmetic(unchecked)]
    pub fn byte_at(self, offset: u256) -> u8 {
        self.input.byte_at(self.start + offset)
    }

    #[arithmetic(unchecked)]
    pub fn word_at(self, offset: u256) -> u256 {
        self.input.word_at(self.start + offset)
    }
}

pub struct StringView<I> {
    pub bytes: BytesView<I>,
}

impl<I> StringView<I>
    where I: ByteInput
{
    pub fn len(self) -> u256 {
        self.bytes.len()
    }

    pub fn is_empty(self) -> bool {
        self.bytes.is_empty()
    }

    pub fn byte_at(self, offset: u256) -> u8 {
        self.bytes.byte_at(offset)
    }

    pub fn word_at(self, offset: u256) -> u256 {
        self.bytes.word_at(offset)
    }
}

/// Owned handle to a Solidity ABI `string` payload stored in linear memory.
///
/// `data` points at the ABI tail payload: the length word followed by packed
/// UTF-8 bytes padded to a whole word count.
pub struct DynString {
    pub data: u256,
    pub len: u256,
    pub size: u256,
}

impl DynString {
    pub fn empty() -> Self {
        DynString {
            data: 0,
            len: 0,
            size: 32,
        }
    }

    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }

    pub fn as_bytes(self) -> Bytes {
        Bytes {
            data: self.data,
            len: self.len,
            size: self.size,
        }
    }

    pub fn view(self) -> StringView<MemoryInput> {
        StringView {
            bytes: self.as_bytes().view(),
        }
    }

    pub fn byte_at(self, index: u256) -> u8 {
        if index >= self.len {
            super::panic()
        }

        let input = MemoryInput {
            base: self.data + 32,
            len: self.len,
        }
        input.byte_at(index)
    }
}

/// Owned handle to a Solidity ABI `bytes` payload stored in linear memory.
///
/// `data` points at the ABI tail payload: the length word followed by packed
/// bytes data padded to a whole word count.
pub struct Bytes {
    pub data: u256,
    pub len: u256,
    pub size: u256,
}

impl Bytes {
    pub fn empty() -> Self {
        Bytes {
            data: 0,
            len: 0,
            size: 32,
        }
    }

    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }

    pub fn view(self) -> BytesView<MemoryInput> {
        let input = MemoryInput {
            base: self.data + 32,
            len: self.len,
        }
        BytesView {
            input,
            start: 0,
            len: self.len,
        }
    }

    pub fn byte_at(self, index: u256) -> u8 {
        if index >= self.len {
            super::panic()
        }

        let input = MemoryInput {
            base: self.data + 32,
            len: self.len,
        }
        input.byte_at(index)
    }
}

pub struct MemoryInput {
    pub base: u256,
    pub len: u256,
}

impl Copy for MemoryInput {}

fn mem_word_load() -> u256
    uses (slot: u256)
{
    slot
}

fn mem_word_at(base: u256, offset: u256) -> u256 {
    let ptr: MemPtr<u256> = MemPtr::from_raw(base + offset)
    with (ptr) {
        mem_word_load()
    }
}

impl ByteInput for MemoryInput {
    fn len(self) -> u256 {
        self.len
    }

    #[arithmetic(unchecked)]
    fn word_at(self, byte_offset: u256) -> u256 {
        mem_word_at(self.base, byte_offset)
    }

    #[arithmetic(unchecked)]
    fn byte_at(self, byte_offset: u256) -> u8 {
        let word_offset = byte_offset - (byte_offset % 32)
        let word = mem_word_at(self.base, word_offset)
        let idx = byte_offset - word_offset
        let shift = (31 - idx) * 8
        (word >> shift).downcast_truncate()
    }
}

/// Owned handle to a Solidity-style dynamic array (`T[]`) stored in linear memory.
///
/// `data` points at the ABI payload for the array: the length word followed by the
/// tuple-encoded element heads/tails.
pub struct DynArray<T> {
    pub data: u256,
    pub len: u256,
    pub size: u256,
}

impl<T> DynArray<T> {
    pub fn empty() -> Self {
        DynArray {
            data: 0,
            len: 0,
            size: 32,
        }
    }

    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }
}

impl AbiSize for u256 {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl<const N: usize> AbiSize for String<N> {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = true
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl<T, const N: usize> AbiSize for [T; N]
    where T: AbiSize
{
    const ENCODED_SIZE: u256 = (N as u256) * abi_slot_size<T>()
    const IS_DYNAMIC: bool = T::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool = T::IS_DYNAMIC
}

impl AbiSize for bool {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

