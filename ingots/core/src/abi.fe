impl AbiSize for i16 {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for i32 {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for i64 {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for i128 {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for i256 {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for usize {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for isize {
    const ENCODED_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl AbiSize for () {
    const ENCODED_SIZE: u256 = 0
    const IS_DYNAMIC: bool = false
    const NEEDS_PARENT_WRAPPER: bool = false
}

impl<T0> AbiSize for (T0,)
    where T0: AbiSize
{
    const ENCODED_SIZE: u256 = abi_slot_size<T0>()
    const IS_DYNAMIC: bool = T0::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool = T0::IS_DYNAMIC
}

impl<T0, T1> AbiSize for (T0, T1)
    where T0: AbiSize, T1: AbiSize
{
    const ENCODED_SIZE: u256 = abi_slot_size<T0>() + abi_slot_size<T1>()
    const IS_DYNAMIC: bool = T0::IS_DYNAMIC || T1::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool = T0::IS_DYNAMIC || T1::IS_DYNAMIC
}

impl<T0, T1, T2> AbiSize for (T0, T1, T2)
    where T0: AbiSize, T1: AbiSize, T2: AbiSize
{
    const ENCODED_SIZE: u256 = abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>()
    const IS_DYNAMIC: bool = T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool = T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC
}

impl<T0, T1, T2, T3> AbiSize for (T0, T1, T2, T3)
    where T0: AbiSize, T1: AbiSize, T2: AbiSize, T3: AbiSize
{
    const ENCODED_SIZE: u256 =
        abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>() + abi_slot_size<T3>()
    const IS_DYNAMIC: bool = T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC
}

impl<T0, T1, T2, T3, T4> AbiSize for (T0, T1, T2, T3, T4)
    where T0: AbiSize,
          T1: AbiSize,
          T2: AbiSize,
          T3: AbiSize,
          T4: AbiSize
{
    const ENCODED_SIZE: u256 =
        abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>() + abi_slot_size<T3>() + abi_slot_size<T4>()
    const IS_DYNAMIC: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC
}

impl<T0, T1, T2, T3, T4, T5> AbiSize for (T0, T1, T2, T3, T4, T5)
    where T0: AbiSize,
          T1: AbiSize,
          T2: AbiSize,
          T3: AbiSize,
          T4: AbiSize,
          T5: AbiSize
{
    const ENCODED_SIZE: u256 =
        abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>() + abi_slot_size<T3>() + abi_slot_size<T4>() + abi_slot_size<T5>()
    const IS_DYNAMIC: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC
}

impl<T0, T1, T2, T3, T4, T5, T6> AbiSize for (T0, T1, T2, T3, T4, T5, T6)
    where T0: AbiSize,
          T1: AbiSize,
          T2: AbiSize,
          T3: AbiSize,
          T4: AbiSize,
          T5: AbiSize,
          T6: AbiSize
{
    const ENCODED_SIZE: u256 =
        abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>() + abi_slot_size<T3>() + abi_slot_size<T4>() + abi_slot_size<T5>() + abi_slot_size<T6>()
    const IS_DYNAMIC: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC || T6::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC || T6::IS_DYNAMIC
}

impl<T0, T1, T2, T3, T4, T5, T6, T7> AbiSize for (T0, T1, T2, T3, T4, T5, T6, T7)
    where T0: AbiSize,
          T1: AbiSize,
          T2: AbiSize,
          T3: AbiSize,
          T4: AbiSize,
          T5: AbiSize,
          T6: AbiSize,
          T7: AbiSize
{
    const ENCODED_SIZE: u256 =
        abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>() + abi_slot_size<T3>() + abi_slot_size<T4>() + abi_slot_size<T5>() + abi_slot_size<T6>() + abi_slot_size<T7>()
    const IS_DYNAMIC: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC || T6::IS_DYNAMIC || T7::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC || T6::IS_DYNAMIC || T7::IS_DYNAMIC
}

impl<T0, T1, T2, T3, T4, T5, T6, T7, T8> AbiSize for (T0, T1, T2, T3, T4, T5, T6, T7, T8)
    where T0: AbiSize,
          T1: AbiSize,
          T2: AbiSize,
          T3: AbiSize,
          T4: AbiSize,
          T5: AbiSize,
          T6: AbiSize,
          T7: AbiSize,
          T8: AbiSize
{
    const ENCODED_SIZE: u256 =
        abi_slot_size<T0>() + abi_slot_size<T1>() + abi_slot_size<T2>() + abi_slot_size<T3>() + abi_slot_size<T4>() + abi_slot_size<T5>() + abi_slot_size<T6>() + abi_slot_size<T7>() + abi_slot_size<T8>()
    const IS_DYNAMIC: bool =
        T0::IS_DYNAMIC || T1::IS_DYNAMIC || T2::IS_DYNAMIC || T3::IS_DYNAMIC || T4::IS_DYNAMIC || T5::IS_DYNAMIC || T6::IS_DYNAMIC || T7::IS_DYNAMIC || T8::IS_DYNAMIC
    const NEEDS_PARENT_WRAPPER: bool =
