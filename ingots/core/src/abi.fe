          T1: AbiSpan<A> + AbiSize
{
    fn abi_end<I: ByteInput>(input: I, base: u256, pos: u256) -> u256 {
        let mut end = pos + abi_slot_size<T0>() + abi_slot_size<T1>()
        end = max_u256(end, abi_field_end<A, T0, I>(input, pos, pos))
        end = max_u256(end, abi_field_end<A, T1, I>(input, pos, pos + abi_slot_size<T0>()))
        end
    }
}

