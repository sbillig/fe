impl<T0> AbiSize for (T0,)
    where T0: AbiSize
{
    const ENCODED_SIZE: u256 = T0::ENCODED_SIZE
}

impl<T0, T1> AbiSize for (T0, T1)
    where T0: AbiSize, T1: AbiSize
{
    const ENCODED_SIZE: u256 = T0::ENCODED_SIZE + T1::ENCODED_SIZE
}

impl<T0, T1, T2> AbiSize for (T0, T1, T2)
    where T0: AbiSize, T1: AbiSize, T2: AbiSize
{
    const ENCODED_SIZE: u256 = T0::ENCODED_SIZE + T1::ENCODED_SIZE + T2::ENCODED_SIZE
}

