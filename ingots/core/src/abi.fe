impl<A: Abi, T, const N: usize> Decode<A> for [T; N]
    where T: Decode<A> + AbiSize + Copy
{
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let first = decode_field<A, T, D>(mut d)
        let mut out: [T; N] = [first; N]
        let mut i: usize = 1
        while i < N {
            out[i] = decode_field<A, T, D>(mut d)
            i += 1
        }
        out
    }
}

impl<A: Abi, T, const N: usize> AbiSpan<A> for [T; N]
    where T: AbiSpan<A> + AbiSize
{
    fn abi_end<I: ByteInput>(input: I, base: u256, pos: u256) -> u256 {
        let _ = base
        let mut head_pos = pos
        let mut end = pos
        let mut i: usize = 0
        while i < N {
            end = max_u256(end, abi_field_end<A, T, I>(input, pos, head_pos))
            head_pos += abi_slot_size<T>()
            i += 1
        }
        max_u256(end, head_pos)
    }
}

impl<A: Abi, T, const N: usize> Encode<A> for [T; N]
    where T: Encode<A> + AbiSize + Copy
{
    const DIRECT_ENCODE: bool = T::DIRECT_ENCODE

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let mut i: usize = 0
        while i < N {
            encode_field<A, T, E>(self[i], mut e)
            i += 1
        }
    }

    #[arithmetic(unchecked)]
    fn encode_to_ptr(own self, ptr: u256) {
        let mut i: usize = 0
        let mut at = ptr
        while i < N {
            self[i].encode_to_ptr(at)
            at += T::ENCODED_SIZE
            i += 1
        }
    }
}
