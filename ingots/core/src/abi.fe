    where T0: Encode<A> + AbiSize,
          T1: Encode<A> + AbiSize,
          T2: Encode<A> + AbiSize,
          T3: Encode<A> + AbiSize,
          T4: Encode<A> + AbiSize,
          T5: Encode<A> + AbiSize,
          T6: Encode<A> + AbiSize,
          T7: Encode<A> + AbiSize,
          T8: Encode<A> + AbiSize,
          T9: Encode<A> + AbiSize,
          T10: Encode<A> + AbiSize
{
    const DIRECT_ENCODE: bool =
        T0::DIRECT_ENCODE && T1::DIRECT_ENCODE && T2::DIRECT_ENCODE && T3::DIRECT_ENCODE && T4::DIRECT_ENCODE && T5::DIRECT_ENCODE && T6::DIRECT_ENCODE && T7::DIRECT_ENCODE && T8::DIRECT_ENCODE && T9::DIRECT_ENCODE && T10::DIRECT_ENCODE

    #[arithmetic(unchecked)]
    #[inline(always)]
    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let base = e.base()
        let mut tail = Self::HEAD_SIZE
        let head1 = base + abi_field_head_size<T0>()
        let head2 = head1 + abi_field_head_size<T1>()
        let head3 = head2 + abi_field_head_size<T2>()
        let head4 = head3 + abi_field_head_size<T3>()
        let head5 = head4 + abi_field_head_size<T4>()
        let head6 = head5 + abi_field_head_size<T5>()
        let head7 = head6 + abi_field_head_size<T6>()
        let head8 = head7 + abi_field_head_size<T7>()
        let head9 = head8 + abi_field_head_size<T8>()
        let head10 = head9 + abi_field_head_size<T9>()
        tail = encode_field_at<A, T0, E>(self.0, mut e, base, base, tail)
        tail = encode_field_at<A, T1, E>(self.1, mut e, base, head1, tail)
        tail = encode_field_at<A, T2, E>(self.2, mut e, base, head2, tail)
        tail = encode_field_at<A, T3, E>(self.3, mut e, base, head3, tail)
        tail = encode_field_at<A, T4, E>(self.4, mut e, base, head4, tail)
        tail = encode_field_at<A, T5, E>(self.5, mut e, base, head5, tail)
        tail = encode_field_at<A, T6, E>(self.6, mut e, base, head6, tail)
        tail = encode_field_at<A, T7, E>(self.7, mut e, base, head7, tail)
        tail = encode_field_at<A, T8, E>(self.8, mut e, base, head8, tail)
        tail = encode_field_at<A, T9, E>(self.9, mut e, base, head9, tail)
        tail = encode_field_at<A, T10, E>(self.10, mut e, base, head10, tail)
        e.set_pos(base + Self::HEAD_SIZE)
    }

    #[arithmetic(unchecked)]
    fn encode_to_ptr(own self, _ ptr: u256) {
        let mut tail = Self::HEAD_SIZE
        let head1 = ptr + abi_field_head_size<T0>()
        let head2 = head1 + abi_field_head_size<T1>()
        let head3 = head2 + abi_field_head_size<T2>()
        let head4 = head3 + abi_field_head_size<T3>()
        let head5 = head4 + abi_field_head_size<T4>()
        let head6 = head5 + abi_field_head_size<T5>()
        let head7 = head6 + abi_field_head_size<T6>()
        let head8 = head7 + abi_field_head_size<T7>()
        let head9 = head8 + abi_field_head_size<T8>()
        let head10 = head9 + abi_field_head_size<T9>()
        tail = encode_field_to_ptr_at<A, T0>(self.0, ptr, ptr, tail)
        tail = encode_field_to_ptr_at<A, T1>(self.1, ptr, head1, tail)
        tail = encode_field_to_ptr_at<A, T2>(self.2, ptr, head2, tail)
        tail = encode_field_to_ptr_at<A, T3>(self.3, ptr, head3, tail)
        tail = encode_field_to_ptr_at<A, T4>(self.4, ptr, head4, tail)
        tail = encode_field_to_ptr_at<A, T5>(self.5, ptr, head5, tail)
        tail = encode_field_to_ptr_at<A, T6>(self.6, ptr, head6, tail)
        tail = encode_field_to_ptr_at<A, T7>(self.7, ptr, head7, tail)
        tail = encode_field_to_ptr_at<A, T8>(self.8, ptr, head8, tail)
        tail = encode_field_to_ptr_at<A, T9>(self.9, ptr, head9, tail)
        tail = encode_field_to_ptr_at<A, T10>(self.10, ptr, head10, tail)
    }
}

impl<A: Abi, T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11> Decode<A>
    for (T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11)
    where T0: Decode<A> + AbiSize, T1: Decode<A> + AbiSize, T2: Decode<A> + AbiSize, T3: Decode<A> + AbiSize, T4: Decode<A> + AbiSize, T5: Decode<A> + AbiSize, T6: Decode<A> + AbiSize, T7: Decode<A> + AbiSize, T8: Decode<A> + AbiSize, T9: Decode<A> + AbiSize, T10: Decode<A> + AbiSize, T11: Decode<A> + AbiSize
{
    fn decode_payload<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let v0: T0 = decode_field<A, T0, D>(mut d)
        let v1: T1 = decode_field<A, T1, D>(mut d)
        let v2: T2 = decode_field<A, T2, D>(mut d)
        let v3: T3 = decode_field<A, T3, D>(mut d)
        let v4: T4 = decode_field<A, T4, D>(mut d)
        let v5: T5 = decode_field<A, T5, D>(mut d)
        let v6: T6 = decode_field<A, T6, D>(mut d)
        let v7: T7 = decode_field<A, T7, D>(mut d)
        let v8: T8 = decode_field<A, T8, D>(mut d)
        let v9: T9 = decode_field<A, T9, D>(mut d)
        let v10: T10 = decode_field<A, T10, D>(mut d)
        let v11: T11 = decode_field<A, T11, D>(mut d)
        (
            v0,
            v1,
            v2,
            v3,
            v4,
            v5,
            v6,
            v7,
            v8,
            v9,
            v10,
            v11,
        )
    }

    #[inline(always)]
    fn decode_from<I: ByteInput>(_ input: I, _ pos: u256) -> Self
        where A::Decoder<I>: AbiDecoder<A>
    {
        let mut head_pos = pos
        let v0: T0 = decode_field_from<A, T0, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T0>()
        let v1: T1 = decode_field_from<A, T1, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T1>()
        let v2: T2 = decode_field_from<A, T2, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T2>()
        let v3: T3 = decode_field_from<A, T3, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T3>()
        let v4: T4 = decode_field_from<A, T4, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T4>()
        let v5: T5 = decode_field_from<A, T5, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T5>()
        let v6: T6 = decode_field_from<A, T6, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T6>()
        let v7: T7 = decode_field_from<A, T7, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T7>()
        let v8: T8 = decode_field_from<A, T8, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T8>()
        let v9: T9 = decode_field_from<A, T9, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T9>()
        let v10: T10 = decode_field_from<A, T10, I>(input, base: pos, head_pos: head_pos)
        head_pos += abi_field_head_size<T10>()
        let v11: T11 = decode_field_from<A, T11, I>(input, base: pos, head_pos: head_pos)
        (v0, v1, v2, v3, v4, v5, v6, v7, v8, v9, v10, v11)
    }
}

impl<A: Abi, T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11> Encode<A>
    for (T0, T1, T2, T3, T4, T5, T6, T7, T8, T9, T10, T11)
    where T0: Encode<A> + AbiSize,
          T1: Encode<A> + AbiSize,
          T2: Encode<A> + AbiSize,
          T3: Encode<A> + AbiSize,
          T4: Encode<A> + AbiSize,
          T5: Encode<A> + AbiSize,
          T6: Encode<A> + AbiSize,
          T7: Encode<A> + AbiSize,
          T8: Encode<A> + AbiSize,
          T9: Encode<A> + AbiSize,
          T10: Encode<A> + AbiSize,
          T11: Encode<A> + AbiSize
{
    const DIRECT_ENCODE: bool =
        T0::DIRECT_ENCODE && T1::DIRECT_ENCODE && T2::DIRECT_ENCODE && T3::DIRECT_ENCODE && T4::DIRECT_ENCODE && T5::DIRECT_ENCODE && T6::DIRECT_ENCODE && T7::DIRECT_ENCODE && T8::DIRECT_ENCODE && T9::DIRECT_ENCODE && T10::DIRECT_ENCODE && T11::DIRECT_ENCODE

    #[arithmetic(unchecked)]
    #[inline(always)]
    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let base = e.base()
        let mut tail = Self::HEAD_SIZE
        let head1 = base + abi_field_head_size<T0>()
        let head2 = head1 + abi_field_head_size<T1>()
        let head3 = head2 + abi_field_head_size<T2>()
        let head4 = head3 + abi_field_head_size<T3>()
        let head5 = head4 + abi_field_head_size<T4>()
        let head6 = head5 + abi_field_head_size<T5>()
        let head7 = head6 + abi_field_head_size<T6>()
        let head8 = head7 + abi_field_head_size<T7>()
        let head9 = head8 + abi_field_head_size<T8>()
        let head10 = head9 + abi_field_head_size<T9>()
        let head11 = head10 + abi_field_head_size<T10>()
        tail = encode_field_at<A, T0, E>(self.0, mut e, base, base, tail)
        tail = encode_field_at<A, T1, E>(self.1, mut e, base, head1, tail)
        tail = encode_field_at<A, T2, E>(self.2, mut e, base, head2, tail)
        tail = encode_field_at<A, T3, E>(self.3, mut e, base, head3, tail)
        tail = encode_field_at<A, T4, E>(self.4, mut e, base, head4, tail)
        tail = encode_field_at<A, T5, E>(self.5, mut e, base, head5, tail)
        tail = encode_field_at<A, T6, E>(self.6, mut e, base, head6, tail)
        tail = encode_field_at<A, T7, E>(self.7, mut e, base, head7, tail)
        tail = encode_field_at<A, T8, E>(self.8, mut e, base, head8, tail)
        tail = encode_field_at<A, T9, E>(self.9, mut e, base, head9, tail)
        tail = encode_field_at<A, T10, E>(self.10, mut e, base, head10, tail)
        tail = encode_field_at<A, T11, E>(self.11, mut e, base, head11, tail)
        e.set_pos(base + Self::HEAD_SIZE)
    }

    #[arithmetic(unchecked)]
    fn encode_to_ptr(own self, _ ptr: u256) {
        let mut tail = Self::HEAD_SIZE
        let head1 = ptr + abi_field_head_size<T0>()
        let head2 = head1 + abi_field_head_size<T1>()
        let head3 = head2 + abi_field_head_size<T2>()
        let head4 = head3 + abi_field_head_size<T3>()
        let head5 = head4 + abi_field_head_size<T4>()
        let head6 = head5 + abi_field_head_size<T5>()
        let head7 = head6 + abi_field_head_size<T6>()
        let head8 = head7 + abi_field_head_size<T7>()
        let head9 = head8 + abi_field_head_size<T8>()
        let head10 = head9 + abi_field_head_size<T9>()
        let head11 = head10 + abi_field_head_size<T10>()
        tail = encode_field_to_ptr_at<A, T0>(self.0, ptr, ptr, tail)
        tail = encode_field_to_ptr_at<A, T1>(self.1, ptr, head1, tail)
        tail = encode_field_to_ptr_at<A, T2>(self.2, ptr, head2, tail)
        tail = encode_field_to_ptr_at<A, T3>(self.3, ptr, head3, tail)
        tail = encode_field_to_ptr_at<A, T4>(self.4, ptr, head4, tail)
        tail = encode_field_to_ptr_at<A, T5>(self.5, ptr, head5, tail)
        tail = encode_field_to_ptr_at<A, T6>(self.6, ptr, head6, tail)
        tail = encode_field_to_ptr_at<A, T7>(self.7, ptr, head7, tail)
        tail = encode_field_to_ptr_at<A, T8>(self.8, ptr, head8, tail)
        tail = encode_field_to_ptr_at<A, T9>(self.9, ptr, head9, tail)
        tail = encode_field_to_ptr_at<A, T10>(self.10, ptr, head10, tail)
        tail = encode_field_to_ptr_at<A, T11>(self.11, ptr, head11, tail)
    }
}

impl<A: Abi, T, const N: usize> Decode<A> for [T; N]
    where T: Decode<A> + AbiSize + Copy
{
    fn decode_payload<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let first = decode_field<A, T, D>(mut d)
        let mut out: [T; N] = [first; N]
        let mut i: usize = 1
        while i < N {
            out[i] = decode_field<A, T, D>(mut d)
            i += 1
        }
        out
    }

    #[inline(always)]
    fn decode_from<I: ByteInput>(_ input: I, _ pos: u256) -> Self
        where A::Decoder<I>: AbiDecoder<A>
    {
        let first = decode_field_from<A, T, I>(input, base: pos, head_pos: pos)
        let mut out: [T; N] = [first; N]
        let mut i: usize = 1
        let mut head_pos = pos + abi_field_head_size<T>()
        while i < N {
            out[i] = decode_field_from<A, T, I>(input, base: pos, head_pos: head_pos)
            head_pos += abi_field_head_size<T>()
            i += 1
        }
        out
    }
}

impl<A: Abi, T, const N: usize> AbiSpan<A> for [T; N]
    where T: AbiSpan<A> + AbiSize + Copy
{
    fn payload_end<I: ByteInput>(_ input: I, base: u256, pos: u256) -> u256 {
        let _ = base
        let mut head_pos = pos
        let mut end = pos
        let mut i: usize = 0
        while i < N {
            end = max_u256(a: end, b: abi_field_end<A, T, I>(input, base: pos, pos: head_pos))
            head_pos += abi_field_head_size<T>()
            i += 1
        }
        max_u256(a: end, b: head_pos)
    }
}

impl<A: Abi, T, const N: usize> Encode<A> for [T; N]
    where T: Encode<A> + AbiSize + Copy
{
    const DIRECT_ENCODE: bool = T::DIRECT_ENCODE

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let mut tail = Self::HEAD_SIZE
        let mut i: usize = 0
        while i < N {
            tail = encode_field<A, T, E>(self[i], mut e, tail)
            i += 1
        }
    }

    #[arithmetic(unchecked)]
    fn encode_to_ptr(own self, _ ptr: u256) {
        let mut tail = Self::HEAD_SIZE
        let mut i: usize = 0
        let mut head_pos = ptr
        while i < N {
            tail = encode_field_to_ptr_at<A, T>(self[i], ptr, head_pos, tail)
            head_pos += abi_field_head_size<T>()
            i += 1
        }
    }
}
