impl<T0> AbiSize for (T0,)
    where T0: AbiSize
{
    const HEAD_SIZE: u256 = abi_field_head_size<T0>()
    const IS_DYNAMIC: bool = T0::IS_DYNAMIC

    #[arithmetic(unchecked)]
    #[inline(always)]
    fn payload_size(self) -> u256 {
        Self::HEAD_SIZE + dynamic_payload_size(self.0)
    }
}

