impl<A: Abi> Decode<A> for u256 {
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        d.read_word()
    }
}

impl<A: Abi> Encode<A> for u256 {
    const DIRECT_ENCODE: bool = true

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        e.write_word(self)
    }

    fn encode_to_ptr(own self, ptr: u256) {
        A::store_word(ptr, self)
    }
}

impl<A: Abi, const N: usize> Decode<A> for String<N> {
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let tail_rel = d.read_word()
        let base = d.base()
        let tail_at = base + tail_rel
        let data_start = tail_at + 32
        let data_len = d.peek_word(tail_at)

        if data_len > 32 || data_len > (N as u256) {
            super::panic()
        }

        let packed = if data_len == 0 {
            0
        } else {
            let shift = if data_len >= 32 { 0 } else { (32 - data_len) * 8 }
            d.peek_word(data_start) >> shift
        }

        packed as String<N>
    }
}

impl<A: Abi, const N: usize> Encode<A> for String<N> {
    const DIRECT_ENCODE: bool = false

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let packed: u256 = self as u256
        let data_len = packed_string_len(packed)

        let tail_size = 32 + round_up_words(data_len)
        let tail_at = e.append_tail(tail_size)
        let offset = tail_at - e.base()

        e.write_word(offset)
        e.write_word_at(tail_at, data_len)

        if data_len != 0 {
            e.write_word_at(tail_at + 32, packed << ((32 - data_len) * 8))
        }
    }

    fn encode_to_ptr(own self, ptr: u256) {
        super::panic()
    }
}

impl<A: Abi> Decode<A> for DynString {
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        let tail_rel = d.read_word()
        let tail_at = d.base() + tail_rel
        let data_len = d.peek_word(tail_at)
        let payload_size = 32 + round_up_words(data_len)
        let data_ptr = d.alloc(payload_size)

        let mut offset: u256 = 0
        while offset < payload_size {
            A::store_word(data_ptr + offset, d.peek_word(tail_at + offset))
            offset += 32
        }

        DynString {
            data: data_ptr,
            len: data_len,
            size: payload_size,
        }
    }
}

impl<A: Abi> Encode<A> for DynString {
    const DIRECT_ENCODE: bool = false

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        let tail_at = e.append_tail(self.size)
        let offset = tail_at - e.base()

        e.write_word(offset)
        if self.data == 0 {
            e.write_word_at(tail_at, self.len)
            return
        }

        let mut offset_in_payload: u256 = 0
        while offset_in_payload < self.size {
            e.write_word_at(
                tail_at + offset_in_payload,
                mem_word_at(self.data, offset_in_payload),
            )
            offset_in_payload += 32
        }
    }

    fn encode_to_ptr(own self, ptr: u256) {
        super::panic()
    }
}

impl<A: Abi> Decode<A> for bool {
    fn decode<D: AbiDecoder<A>>(_ d: mut D) -> Self {
        A::decode_bool_word(d.read_word())
    }
}

impl<A: Abi> Encode<A> for bool {
    const DIRECT_ENCODE: bool = true

    fn encode<E: AbiEncoder<A>>(own self, _ e: mut E) {
        if self {
            e.write_word(1)
        } else {
            e.write_word(0)
        }
    }

    fn encode_to_ptr(own self, ptr: u256) {
        if self {
            A::store_word(ptr, 1)
        } else {
            A::store_word(ptr, 0)
        }
    }
}

