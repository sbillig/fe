impl<A: Abi> AbiSpan<A> for u256 {
    fn abi_end<I: ByteInput>(input: I, base: u256, pos: u256) -> u256 {
        pos + 32
    }
}

impl<A: Abi, const N: usize> AbiSpan<A> for String<N> {
    fn abi_end<I: ByteInput>(input: I, base: u256, pos: u256) -> u256 {
        let tail_rel = input.word_at(pos)
        let tail_at = base + tail_rel
        let data_len = input.word_at(tail_at)
        tail_at + 32 + round_up_words(data_len)
    }
}

