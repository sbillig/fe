use ingot::Copy
use ingot::EffectHandle
use ingot::MemPtr
use ingot::num::{IntDowncast, WordValue}

// EVM Cancun+ (EIP-5656) memory copy. Used to speed up ABI payload copying.
extern {
    fn mcopy(dest: u256, addr: u256, len: u256)
}

/// Errors returned by ABI decoding/encoding helpers.
pub enum AbiError {
    InputTooShort,
    OutOfBounds,
    InvalidSelector,
    InvalidOffset,
    NonCanonical,
    InvalidBool,
    InvalidUtf8,
    LengthOverflow,
    AllocationFailed,
}

/// Generic read-only byte input for ABI decoding.
///
/// Implementations may return padded values (e.g. EVM calldata loads) so callers
/// must use `len()` to enforce bounds/canonicality.
pub trait ByteInput: Copy {
    fn len(self) -> u256
    fn word_at(self, _ byte_offset: u256) -> u256
    fn byte_at(self, _ byte_offset: u256) -> u8
    /// Copy `len` bytes starting at `src_offset` into linear memory at `dest`.
    ///
    /// Callers currently rely on `len` being a whole number of words.
    fn copy_to_memory(self, dest: u256, src_offset: u256, len: u256)

    /// Copy an already validated, word-aligned range into linear memory.
    ///
    /// Callers must validate bounds and `len % 32 == 0` before using this fast
    /// path. Implementations may skip all checks.
    fn copy_to_memory_unchecked_aligned(self, dest: u256, src_offset: u256, len: u256) {
        self.copy_to_memory(dest: dest, src_offset: src_offset, len: len)
    }
}

/// First-word prefix used for fast dispatch.
pub struct Prefix {
    pub len: u256,
    pub word0: u256,
}

pub fn prefix<I: ByteInput>(input: I) -> Prefix {
    Prefix {
        len: input.len(),
        word0: input.word_at(0),
    }
}

/// Generic cursor over a `ByteInput`.
pub struct Cursor<I> {
    pub input: I,
    pub pos: u256,
}

impl<I> Cursor<I>
    where I: ByteInput
{
    #[inline(always)]
    pub fn new(input: own I) -> Self {
        Cursor {
            input,
            pos: 0,
        }
    }

    #[inline(always)]
    pub fn fork(self, _ pos: u256) -> Self {
        Cursor {
            input: self.input,
            pos,
        }
    }

    #[arithmetic(unchecked)]
    pub fn read_u8(mut self) -> u8 {
        let b = self.input.byte_at(self.pos)
        self.pos = self.pos + 1
        b
    }

    #[arithmetic(unchecked)]
    pub fn read_word(mut self) -> u256 {
        let w = self.input.word_at(self.pos)
        self.pos = self.pos + 32
        w
    }

    pub fn peek_word(self, _ at: u256) -> u256 {
        self.input.word_at(at)
    }
}

/// ABI definition (selector width/format).
pub trait Abi {
    type Selector
    /// Higher-kinded type constructor for a decoder over some `ByteInput`.
    type Decoder: * -> *
    /// ABI encoder type.
    type Encoder: AbiEncoder<Self>

    /// Size of the selector in bytes.
    const SELECTOR_SIZE: u256

    fn selector_from_prefix(_: u256) -> Self::Selector

    fn decode_bool_word(_: u256) -> bool
    fn decode_u8_word(_: u256) -> u8
    fn decode_u16_word(_: u256) -> u16
    fn decode_u32_word(_: u256) -> u32
    fn decode_u64_word(_: u256) -> u64
    fn decode_u128_word(_: u256) -> u128
    fn decode_i8_word(_: u256) -> i8
    fn decode_i16_word(_: u256) -> i16
    fn decode_i32_word(_: u256) -> i32
    fn decode_i64_word(_: u256) -> i64
    fn decode_i128_word(_: u256) -> i128
    fn decode_error() -> !

    fn decoder_new<I: ByteInput>(_: own I) -> Self::Decoder<I>
    fn decoder_with_base<I: ByteInput>(_: own I, _ base: u256) -> Self::Decoder<I>

    fn alloc(_ size: u256) -> u256
    fn encoder_new(_ size: u256) -> Self::Encoder
    fn encoder_at(_ base: u256) -> Self::Encoder {
        let mut e = Self::encoder_new(0)
        e.set_base(base)
        e.set_pos(base)
        e
    }
    fn store_word(ptr: u256, value: u256)
}

/// ABI decoder with cursor state and an allocation hook.
pub trait AbiDecoder<A: Abi> {
    type Input: ByteInput

    fn input(self) -> Self::Input
    fn base(self) -> u256
    fn set_base(mut self, _ new_base: u256)
    fn pos(self) -> u256
    fn set_pos(mut self, _ new_pos: u256)

    fn read_u8(mut self) -> u8
    fn read_word(mut self) -> u256
    fn peek_word(self, _ at: u256) -> u256

    fn alloc(mut self, _ size: u256) -> u256
}

/// ABI encoder with cursor state over a fixed output buffer.
pub trait AbiEncoder<A: Abi> {
    fn base(self) -> u256
    fn set_base(mut self, _ new_base: u256)
    fn pos(self) -> u256
    fn set_pos(mut self, _ new_pos: u256)

    fn write_u8(mut self, _ v: u8)
    fn write_word(mut self, _ v: u256)
    fn write_word_at(mut self, at: u256, value: u256)
}

/// ABI payload layout metadata and exact runtime payload size.
pub trait AbiSize {
    const HEAD_SIZE: u256
    const IS_DYNAMIC: bool

    fn payload_size(self) -> u256 {
        Self::HEAD_SIZE
    }
}

pub trait AbiSpan<A: Abi>: AbiSize {
    fn payload_end<I: ByteInput>(_: I, base: u256, pos: u256) -> u256
}

pub trait Decode<A: Abi> {
    fn decode_payload<D: AbiDecoder<A>>(_: mut D) -> Self

    fn decode_from<I: ByteInput>(_ input: I, _ pos: u256) -> Self
        where A::Decoder<I>: AbiDecoder<A>
    {
        let mut d = A::decoder_with_base(input, pos)
        Self::decode_payload(mut d)
    }

    fn decode_from_with_input_len<I: ByteInput>(_ input: I, _ pos: u256, _ input_len: u256) -> Self
        where A::Decoder<I>: AbiDecoder<A>
    {
        Self::decode_from(input, pos)
    }
}

pub trait Encode<A: Abi>: AbiSize {
    const DIRECT_ENCODE: bool

    fn encode<E: AbiEncoder<A>>(own self, _: mut E)
    /// Write this value's complete ABI payload at `ptr`.
    fn encode_to_ptr(own self, _ ptr: u256)
}

pub fn decode_or_revert<A: Abi, T, D>(d: mut D) -> T
    where T: Decode<A>, D: AbiDecoder<A>
{
    T::decode_payload(d)
}

pub const fn abi_field_head_size<T: AbiSize>() -> u256 {
    if T::IS_DYNAMIC {
        return 32
    }
    T::HEAD_SIZE
}

pub const fn abi_payload_head_size<T: AbiSize>() -> u256 {
    T::HEAD_SIZE
}

pub const fn abi_single_root_head_size<T: AbiSize>() -> u256 {
    abi_field_head_size<T>()
}

pub fn abi_payload_size<T: AbiSize>(_ value: T) -> u256 {
    value.payload_size()
}

pub fn abi_field_size<T: AbiSize>(_ value: T) -> u256 {
    let payload_size = value.payload_size()
    if T::IS_DYNAMIC {
        return 32 + payload_size
    }
    payload_size
}

pub fn abi_single_root_size<T: AbiSize>(_ value: T) -> u256 {
    abi_field_size(value)
}

pub fn dynamic_payload_size<T: AbiSize>(_ value: T) -> u256 {
    if T::IS_DYNAMIC {
        return value.payload_size()
    }
    0
}

pub fn decode_payload_root<A: Abi, T, D>(_ d: mut D) -> T
    where T: Decode<A>,
          D: AbiDecoder<A>
{
    T::decode_payload(d)
}

pub fn decode_single_root<A: Abi, T, D>(_ d: mut D) -> T
    where T: Decode<A> + AbiSize,
          D: AbiDecoder<A>
{
    decode_field<A, T, D>(mut d)
}

#[inline(always)]
pub fn decode_field<A: Abi, T, D>(_ d: mut D) -> T
    where T: Decode<A> + AbiSize,
          D: AbiDecoder<A>
{
    if T::IS_DYNAMIC {
        let tail_rel = d.read_word()
        let parent_base = d.base()
        let parent_pos = d.pos()
        d.set_base(parent_base + tail_rel)
        d.set_pos(d.base())
        let value = T::decode_payload(mut d)
        d.set_base(parent_base)
        d.set_pos(parent_pos)
        return value
    }

    T::decode_payload(d)
}

#[inline(always)]
pub fn decode_field_from<A: Abi, T, I>(_ input: I, base: u256, head_pos: u256) -> T
    where T: Decode<A> + AbiSize,
          I: ByteInput,
          A::Decoder<I>: AbiDecoder<A>
{
    if T::IS_DYNAMIC {
        let tail_rel = input.word_at(head_pos)
        return T::decode_from(input, base + tail_rel)
    }

    T::decode_from(input, head_pos)
}

#[inline(always)]
pub fn decode_field_from_with_input_len<A: Abi, T, I>(_ input: I, base: u256, head_pos: u256, input_len: u256) -> T
    where T: Decode<A> + AbiSize,
          I: ByteInput,
          A::Decoder<I>: AbiDecoder<A>
{
    if T::IS_DYNAMIC {
        let tail_rel = input.word_at(head_pos)
        return T::decode_from_with_input_len(input, base + tail_rel, input_len)
    }

    T::decode_from(input, head_pos)
}

fn decode_field_at<A: Abi, T, D>(d: mut D, pos: u256) -> T
    where T: Decode<A> + AbiSize,
          D: AbiDecoder<A>
{
    d.set_pos(pos)
    decode_field<A, T, D>(mut d)
}

#[arithmetic(unchecked)]
pub fn encode_root<A: Abi, T, E>(_ value: own T, _ e: mut E)
    where T: Encode<A>, E: AbiEncoder<A>
{
    if T::DIRECT_ENCODE {
        let at = e.pos()
        value.encode_to_ptr(at)
        e.set_pos(at + T::HEAD_SIZE)
        return
    }

    value.encode(mut e)
}

#[arithmetic(unchecked)]
pub fn encode_single_root<A: Abi, T, E>(_ value: own T, _ e: mut E)
    where T: Encode<A> + AbiSize, E: AbiEncoder<A>
{
    let tail = abi_single_root_head_size<T>()
    let _ = encode_field<A, T, E>(value, mut e, tail)
}

#[arithmetic(unchecked)]
pub fn encode_field<A: Abi, T, E>(_ value: own T, _ e: mut E, _ tail: u256) -> u256
    where T: Encode<A> + AbiSize, E: AbiEncoder<A>
{
    if T::IS_DYNAMIC {
        let child_base = e.base() + tail
        let child_size = value.payload_size()
        e.write_word(tail)

        value.encode_to_ptr(child_base)
        return tail + child_size
    }

    if T::DIRECT_ENCODE {
        let at = e.pos()
        value.encode_to_ptr(at)
        e.set_pos(at + T::HEAD_SIZE)
        return tail
    }

    value.encode(mut e)
    tail
}

#[arithmetic(unchecked)]
#[inline(always)]
fn encode_field_at<A: Abi, T, E>(_ value: own T, _ e: mut E, _ base: u256, _ head_pos: u256, _ tail: u256) -> u256
    where T: Encode<A> + AbiSize, E: AbiEncoder<A>
{
    if T::IS_DYNAMIC {
        let child_base = base + tail
        let child_size = value.payload_size()
        e.write_word_at(at: head_pos, value: tail)

        value.encode_to_ptr(child_base)
        return tail + child_size
    }

    if T::DIRECT_ENCODE {
        value.encode_to_ptr(head_pos)
        return tail
    }

    e.set_pos(head_pos)
    value.encode(mut e)
    tail
}

#[arithmetic(unchecked)]
#[inline(always)]
pub fn encode_field_to_ptr_at<A: Abi, T>(_ value: own T, _ base: u256, _ head_pos: u256, _ tail: u256) -> u256
    where T: Encode<A> + AbiSize
{
    if T::IS_DYNAMIC {
        let child_base = base + tail
        let child_size = value.payload_size()
        A::store_word(ptr: head_pos, value: tail)
        value.encode_to_ptr(child_base)
        return tail + child_size
    }

    if T::DIRECT_ENCODE {
        value.encode_to_ptr(head_pos)
        return tail
    }

    let mut e = A::encoder_at(head_pos)
    value.encode(mut e)
    tail
}

pub fn encode_alloc<A: Abi, T>(_ value: own T) -> (u256, u256)
    where T: Encode<A> + AbiSize
{
    let total = abi_payload_size(value)
    let base = if total == 0 { 0 } else { A::alloc(total) }
    if T::IS_DYNAMIC || T::DIRECT_ENCODE {
        value.encode_to_ptr(base)
    } else {
        let mut e = A::encoder_at(base)
        value.encode(mut e)
    }
    (base, total)
}

pub fn encode_single_root_alloc<A: Abi, T>(_ value: own T) -> (u256, u256)
    where T: Encode<A> + AbiSize
{
    let total = abi_single_root_size(value)
    let base = if total == 0 { 0 } else { A::alloc(total) }
    if T::IS_DYNAMIC {
        A::store_word(ptr: base, value: 32)
        value.encode_to_ptr(base + 32)
    } else if T::DIRECT_ENCODE {
        value.encode_to_ptr(base)
    } else {
        let mut e = A::encoder_at(base)
        value.encode(mut e)
    }
    (base, total)
}

fn max_u256(a: u256, b: u256) -> u256 {
    if a >= b {
        a
    } else {
        b
    }
}

pub fn abi_field_end<A: Abi, T, I>(_ input: I, base: u256, pos: u256) -> u256
    where T: AbiSpan<A> + AbiSize,
          I: ByteInput
{
    if T::IS_DYNAMIC {
        let tail_rel = input.word_at(pos)
        let tail_at = base + tail_rel
        return T::payload_end(input, base: tail_at, pos: tail_at)
    }

    T::payload_end(input, base: base, pos: pos)
}

fn round_up_words(_ len: u256) -> u256 {
    if len == 0 {
        return 0
    }
    (((len - 1) / 32) + 1) * 32
}

#[inline(always)]
fn checked_dynamic_payload<A: Abi, I: ByteInput>(_ input: I, _ pos: u256) -> (u256, u256) {
    let input_len = input.len()
    checked_dynamic_payload_with_input_len<A, I>(input, pos, input_len)
}

#[inline(always)]
fn checked_dynamic_payload_with_input_len<A: Abi, I: ByteInput>(_ input: I, _ pos: u256, _ input_len: u256) -> (u256, u256) {
    let len_end = pos + 32
    if len_end < pos || len_end > input_len {
        A::decode_error()
    }

    let data_len = input.word_at(pos)
    let payload_size = 32 + round_up_words(data_len)
    let payload_end = pos + payload_size
    if payload_end < pos || payload_end > input_len {
        A::decode_error()
    }

    (data_len, payload_size)
}

#[inline(always)]
fn copy_dynamic_payload_from<A: Abi, I: ByteInput>(_ input: I, _ pos: u256) -> (u256, u256, u256) {
    let input_len = input.len()
    copy_dynamic_payload_from_with_input_len<A, I>(input, pos, input_len)
}

fn copy_dynamic_payload_from_with_input_len<A: Abi, I: ByteInput>(_ input: I, _ pos: u256, _ input_len: u256) -> (u256, u256, u256) {
    let payload: (u256, u256) = checked_dynamic_payload_with_input_len<A, I>(input, pos, input_len)
    let data_len = payload.0
    let payload_size = payload.1
    let data_ptr = A::alloc(payload_size)

    input.copy_to_memory_unchecked_aligned(dest: data_ptr, src_offset: pos, len: payload_size)

    (data_ptr, data_len, payload_size)
}

// Fe strings are currently represented as a single packed word. This limits the
// ABI path here to strings whose runtime payload fits in 32 bytes.
fn packed_string_len(_ word: u256) -> u256 {
    let mut len: u256 = 0
    let mut value = word
    while value != 0 {
        len += 1
        value = value >> 8
    }
    len
}

pub struct BytesView<I> {
    pub input: I,
    pub start: u256,
    pub len: u256,
}

impl<I> Copy for BytesView<I>
    where I: Copy
{}

impl<I> BytesView<I>
    where I: ByteInput
{
    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }

    #[arithmetic(unchecked)]
    pub fn byte_at(self, _ offset: u256) -> u8 {
        self.input.byte_at(self.start + offset)
    }

    #[arithmetic(unchecked)]
    #[inline(always)]
    pub fn word_at(self, _ offset: u256) -> u256 {
        self.input.word_at(self.start + offset)
    }
}

pub struct StringView<I> {
    pub bytes: BytesView<I>,
}

impl<I> Copy for StringView<I>
    where I: Copy
{}

impl<I> StringView<I>
    where I: ByteInput
{
    pub fn len(self) -> u256 {
        self.bytes.len()
    }

    pub fn is_empty(self) -> bool {
        self.bytes.is_empty()
    }

    pub fn byte_at(self, _ offset: u256) -> u8 {
        self.bytes.byte_at(offset)
    }

    pub fn word_at(self, _ offset: u256) -> u256 {
        self.bytes.word_at(offset)
    }
}

/// Owned handle to a Solidity ABI `string` payload stored in linear memory.
///
/// `data` points at the ABI tail payload: the length word followed by packed
/// UTF-8 bytes padded to a whole word count.
pub struct DynString {
    pub data: u256,
    pub len: u256,
    pub size: u256,
}

impl DynString {
    pub fn empty() -> Self {
        DynString {
            data: 0,
            len: 0,
            size: 32,
        }
    }

    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }

    pub fn as_bytes(self) -> Bytes {
        Bytes::from_abi_tail(data: self.data, len: self.len, size: self.size)
    }

    pub fn view(self) -> StringView<MemoryInput> {
        StringView {
            bytes: self.as_bytes().view(),
        }
    }

    pub fn byte_at(self, _ index: u256) -> u8 {
        if index >= self.len {
            super::panic()
        }

        let input = MemoryInput {
            base: self.data + 32,
            len: self.len,
        }
        input.byte_at(index)
    }
}

/// Owned handle to a Solidity ABI `bytes` payload stored in linear memory.
///
/// `data` points at the ABI tail payload: the length word followed by packed
/// bytes data padded to a whole word count.
pub struct Bytes {
    pub data: u256,
    pub len: u256,
    pub size: u256,
}

impl Bytes {
    pub fn empty() -> Self {
        Bytes::from_abi_tail(data: 0, len: 0, size: 32)
    }

    pub fn from_abi_tail(data: u256, len: u256, size: u256) -> Self {
        Bytes { data, len, size }
    }

    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }

    #[inline(always)]
    pub fn view(self) -> BytesView<MemoryInput> {
        let input = MemoryInput {
            base: self.data + 32,
            len: self.len,
        }
        BytesView {
            input,
            start: 0,
            len: self.len,
        }
    }

    pub fn byte_at(self, _ index: u256) -> u8 {
        if index >= self.len {
            super::panic()
        }

        let input = MemoryInput {
            base: self.data + 32,
            len: self.len,
        }
        input.byte_at(index)
    }
}

pub struct MemoryInput {
    pub base: u256,
    pub len: u256,
}

impl Copy for MemoryInput {}

fn mem_word_load() -> u256
    uses (slot: u256)
{
    slot
}

fn mem_word_store(value: u256) uses (slot: mut u256) {
    slot = value
}

#[arithmetic(unchecked)]
#[inline(always)]
fn mem_word_at(base: u256, offset: u256) -> u256 {
    let ptr: MemPtr<u256> = MemPtr::from_raw(base + offset)
    with (ptr) {
        mem_word_load()
    }
}

impl ByteInput for MemoryInput {
    fn len(self) -> u256 {
        self.len
    }

    #[arithmetic(unchecked)]
    #[inline(always)]
    fn word_at(self, _ byte_offset: u256) -> u256 {
        mem_word_at(base: self.base, offset: byte_offset)
    }

    #[arithmetic(unchecked)]
    fn byte_at(self, _ byte_offset: u256) -> u8 {
        let word_offset = byte_offset - (byte_offset % 32)
        let word = mem_word_at(base: self.base, offset: word_offset)
        let idx = byte_offset - word_offset
        let shift = (31 - idx) * 8
        (word >> shift).downcast_truncate()
    }

    fn copy_to_memory(self, dest: u256, src_offset: u256, len: u256) {
        if len % 32 != 0 {
            super::panic()
        }

        let end = src_offset + len
        if end < src_offset || end > self.len {
            super::panic()
        }

        mcopy(dest: dest, addr: self.base + src_offset, len: len)
    }

    fn copy_to_memory_unchecked_aligned(self, dest: u256, src_offset: u256, len: u256) {
        mcopy(dest: dest, addr: self.base + src_offset, len: len)
    }
}

/// Owned handle to a Solidity-style dynamic array (`T[]`) stored in linear memory.
///
/// `data` points at the ABI payload for the array: the length word followed by the
/// tuple-encoded element heads/tails.
pub struct DynArray<T> {
    pub data: u256,
    pub len: u256,
    pub size: u256,
}

impl<T> DynArray<T> {
    pub fn empty() -> Self {
        DynArray {
            data: 0,
            len: 0,
            size: 32,
        }
    }

    pub fn len(self) -> u256 {
        self.len
    }

    pub fn is_empty(self) -> bool {
        self.len == 0
    }
}

impl AbiSize for u256 {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
}

impl<const N: usize> AbiSize for String<N> {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = true

    fn payload_size(self) -> u256 {
        32 + round_up_words(packed_string_len(self.to_word()))
    }
}

impl<T, const N: usize> AbiSize for [T; N]
    where T: AbiSize + Copy
{
    const HEAD_SIZE: u256 = (N as u256) * abi_field_head_size<T>()
    const IS_DYNAMIC: bool = T::IS_DYNAMIC

    fn payload_size(self) -> u256 {
        if !T::IS_DYNAMIC {
            return Self::HEAD_SIZE
        }

        let mut total = Self::HEAD_SIZE
        let mut i: usize = 0
        while i < N {
            total += self[i].payload_size()
            i += 1
        }
        total
    }
}

impl AbiSize for bool {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
}

impl AbiSize for u8 {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
}

impl AbiSize for u16 {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
}

impl AbiSize for u32 {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
}

impl AbiSize for u64 {
    const HEAD_SIZE: u256 = 32
    const IS_DYNAMIC: bool = false
}

impl AbiSize for u128 {
